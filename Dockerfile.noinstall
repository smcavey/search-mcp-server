# No npm install Dockerfile - everything pre-built
FROM --platform=linux/amd64 registry.access.redhat.com/ubi9/nodejs-18:latest

WORKDIR /app

# Switch to root for setup
USER root

# Copy everything pre-built
COPY package*.json ./
COPY dist ./dist
COPY node_modules ./node_modules

# Switch back to default user (non-root)
USER 1001

# Expose port
EXPOSE 3000

# Set environment variables
ENV PORT=3000
ENV NODE_ENV=production

# Start the application
CMD ["node", "dist/http-server.js"]